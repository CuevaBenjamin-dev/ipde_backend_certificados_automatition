def normalize_spaces(s: str) -> str:
    return re.sub(r"\s+", " ", (s or "").strip())


def wrap_words_to_lines(text: str, max_lines: int, target_line_len: int) -> tuple[str, int]:
    words = normalize_spaces(text).split(" ")
    lines = []
    cur = ""

    for w in words:
        if not cur:
            cur = w
            continue
        if len(cur) + 1 + len(w) > target_line_len:
            lines.append(cur)
            cur = w
        else:
            cur += " " + w

    if cur:
        lines.append(cur)

    return "\n".join(lines[:max_lines]), len(lines)

def can_use_openai() -> bool:
