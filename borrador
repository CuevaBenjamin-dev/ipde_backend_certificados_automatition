def replace_in_text_frame_preserve_font(text_frame, mapping, font_overrides=None):
    font_overrides = font_overrides or {}

    for paragraph in text_frame.paragraphs:
        for run in paragraph.runs:
            if not run.text:
                continue

            for k, v in mapping.items():
                if k in run.text:
                    run.text = run.text.replace(k, v)

                    # si este placeholder requiere tamaño fijo (módulos), lo aplicamos
                    if k in font_overrides:
                        run.font.size = Pt(font_overrides[k])


def replace_in_shape(shape, mapping, font_overrides=None):
    if shape.has_text_frame:
        replace_in_text_frame_preserve_font(shape.text_frame, mapping, font_overrides)

    if shape.has_table:
        for row in shape.table.rows:
            for cell in row.cells:
                replace_in_text_frame_preserve_font(cell.text_frame, mapping, font_overrides)

    if shape.shape_type == MSO_SHAPE_TYPE.GROUP:
        for s in shape.shapes:
            replace_in_shape(s, mapping, font_overrides)


def replace_placeholders(prs, mapping, font_overrides=None):
    for slide in prs.slides:
        for shape in slide.shapes:
            replace_in_shape(shape, mapping, font_overrides)

        if slide.has_notes_slide:
            for shape in slide.notes_slide.shapes:
                replace_in_shape(shape, mapping, font_overrides)

    for layout in prs.slide_layouts:
        for shape in layout.shapes:
            replace_in_shape(shape, mapping, font_overrides)

    for master in prs.slide_masters:
        for shape in master.shapes:
            replace_in_shape(shape, mapping, font_overrides)


