def ai_compact_text(original: str, max_chars: int, max_lines: int, purpose: str) -> str:
    if not can_use_openai():
        # fallback sin IA: recorte duro + wrap simple
        s = normalize_spaces(original).upper()
        s = s[:max_chars].rstrip()
        return s
    # IA solo cuando no entra (como acordamos)
    prompt = f"""
Devuelve SOLO texto (sin comillas, sin listas), en MAYÚSCULAS, para {purpose} de un certificado.
REGLAS DURAS:
- Máximo {max_chars} caracteres (incluye espacios)
- Máximo {max_lines} líneas (usa saltos de línea si es necesario)
- Mantén el significado académico
- Español, formal
TEXTO ORIGINAL:
{original}
""".strip()

    r = client.responses.create(
        model="gpt-5-mini",
        input=[
            {"role": "system", "content": "Eres un editor académico extremadamente estricto."},
            {"role": "user", "content": prompt},
        ],
    )
    return normalize_spaces(r.output_text).upper()


def ensure_tema_fits(tipo: str, tema: str) -> str:
    rules = TEMA_RULES[tipo]
    tema_up = normalize_spaces(tema).upper()

    # heurística de chars por línea (balanceada)
    target_len = max(18, rules["max_chars"] // rules["max_lines"])

    # 1) wrap primero
    if len(tema_up) <= rules["max_chars"]:
        wrapped, lines_count = wrap_words_to_lines(tema_up, rules["max_lines"], target_len)
        if lines_count <= rules["max_lines"]:
            return wrapped

    # 2) IA solo si no entra
    compact = ai_compact_text(tema_up, rules["max_chars"], rules["max_lines"], "el TÍTULO/TEMA")
    wrapped, _ = wrap_words_to_lines(compact, rules["max_lines"], target_len)
    return wrapped


def choose_modulo_text_and_font(tipo: str, modulo: str) -> tuple[str, float]:
    t = normalize_spaces(modulo).upper()
    rules = MODULO_RULES[tipo]

    # Diplomado / Programa
    if "max_chars" in rules:
        if len(t) <= rules["max_chars"]:
            return t, rules["font_prefer"]
        compact = ai_compact_text(t, rules["max_chars"], 1, "un MÓDULO")
        return compact, rules["font_min"]

    # Curso / Capacitación / Actualización
    if len(t) <= rules["max_chars_10"]:
        return t, 10.0
    if len(t) <= rules["max_chars_9_5"]:
        return t, 9.5

    compact = ai_compact_text(t, rules["max_chars_9_5"], 1, "un MÓDULO")
    return compact, 9.5


